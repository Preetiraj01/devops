app.java
package com.example;

/**
 * Hello world!
 *
 */
public class App 
{
    public static int addNum(int a,int b){
        return a+b;
    }
    public static void main( String[] args )
    {
        App app=new App();
        int result=app.addNum(2,3);
        System.out.println( "2+3="+result );
    }
}

